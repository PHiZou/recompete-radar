# Postgres (Neon free tier works great)
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@localhost:5432/sunlight

# Where ingested parquet lands locally
DATA_DIR=./data/raw

# Optional: SAM.gov API key for Phase 2 opportunities ingest
SAM_API_KEY=

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
